# LLM 配置（拆解任务时使用）
LLM_PROVIDER=claude
LLM_API_KEY=sk-xxx
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=
# LLM 连接超时（毫秒），默认 180000（3 分钟），仅用于初始连接，流式输出不超时
# LLM_TIMEOUT_MS=180000

# 服务器配置
PORT=5173
DATABASE_PATH=./data/tracker.db

# API Keys（Agent 连接密钥，逗号分隔）
API_KEYS=mt_key_for_agent_1,mt_key_for_agent_2

# 管理员密码
ADMIN_PASSWORD=changeme

# 日志配置
LOG_LEVEL=info
